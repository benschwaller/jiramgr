#!/usr/bin/env python3
"""jiramgr — Simple Jira card manager.

Usage:
    jiramgr setup                              Interactive setup
    jiramgr story "Add dark mode"              Create a story
    jiramgr task "Update deps" -e EPIC-42      Create a task, skip epic picker
    jiramgr spike "Research K8s" --sprint      Create a spike, auto-sprint
    jiramgr mine                               List your sprint cards
    jiramgr mine --backlog                     List your backlog cards
    jiramgr move ISSUE-123                     Interactive status picker
    jiramgr move ISSUE-123 "Done"              Move directly
    jiramgr comment ISSUE-123 "text"           Add a comment
"""

import argparse
import base64
import getpass
import json
import os
import re
import subprocess
import sys
import tempfile
import urllib.error
import urllib.request
from urllib.parse import quote

JIRAMGR_DIR = os.path.expanduser("~/.jiramgr")
CONFIG_PATH = os.path.join(JIRAMGR_DIR, "config.json")
TEMPLATES_DIR = os.path.join(JIRAMGR_DIR, "templates")

# Legacy config path (pre-migration)
OLD_CONFIG_PATH = os.path.expanduser("~/.jiramgr.json")


# ── Colors ───────────────────────────────────────────────────

class C:
    RED = "\033[0;31m"
    GREEN = "\033[0;32m"
    YELLOW = "\033[1;33m"
    BOLD = "\033[1m"
    NC = "\033[0m"


def ok(msg):
    print(f"{C.GREEN}{msg}{C.NC}")


def err(msg):
    print(f"{C.RED}ERROR:{C.NC} {msg}", file=sys.stderr)


def warn(msg):
    print(f"{C.YELLOW}WARN:{C.NC} {msg}", file=sys.stderr)


# ── Config ───────────────────────────────────────────────────

def load_config():
    # Migrate old config location if needed
    if not os.path.exists(CONFIG_PATH) and os.path.exists(OLD_CONFIG_PATH):
        os.makedirs(JIRAMGR_DIR, exist_ok=True)
        os.rename(OLD_CONFIG_PATH, CONFIG_PATH)

    if not os.path.exists(CONFIG_PATH):
        err(f"No config found. Run: {C.BOLD}jiramgr setup{C.NC}")
        sys.exit(1)
    if os.path.islink(CONFIG_PATH):
        err(f"Config file is a symlink — refusing to read. Remove and re-run setup.")
        sys.exit(1)
    st = os.stat(CONFIG_PATH)
    if st.st_mode & 0o077:
        err(f"Config file is world-readable (mode {oct(st.st_mode & 0o777)}). Run: chmod 600 {CONFIG_PATH}")
        sys.exit(1)
    with open(CONFIG_PATH) as f:
        return json.load(f)


def save_config(config):
    os.makedirs(JIRAMGR_DIR, exist_ok=True)
    fd = os.open(CONFIG_PATH, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
    with os.fdopen(fd, "w") as f:
        json.dump(config, f, indent=2)


# ── API ──────────────────────────────────────────────────────

class JiraError(Exception):
    pass


def api(config, method, path, body=None):
    """Make a Jira REST API request. Returns parsed JSON."""
    url = config["base_url"] + path
    auth = base64.b64encode(
        f"{config['user']}:{config['api_token']}".encode()
    ).decode()

    headers = {
        "Authorization": f"Basic {auth}",
        "Content-Type": "application/json",
    }

    data = json.dumps(body).encode() if body else None
    req = urllib.request.Request(url, data=data, headers=headers, method=method)

    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            if resp.status == 204:
                return {}
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        raw = e.read().decode()
        try:
            msg = json.loads(raw).get("message", raw[:300])
        except json.JSONDecodeError:
            msg = raw[:300]
        raise JiraError(f"HTTP {e.code}: {msg}")
    except urllib.error.URLError as e:
        raise JiraError(f"Connection failed: {e.reason}")


def jql_search(config, jql, fields, max_results=50):
    """Search issues via JQL. Returns list of issue dicts."""
    result = api(config, "POST", "/rest/api/3/search/jql", {
        "jql": jql,
        "fields": fields,
        "maxResults": max_results,
    })
    return result.get("issues", [])


def find_active_sprint(config):
    """Return the ID of the first active sprint, or None."""
    result = api(config, "GET", "/rest/agile/1.0/sprint?state=active&maxResults=1")
    values = result.get("values", [])
    return values[0]["id"] if values else None


# ── Helpers ──────────────────────────────────────────────────

def text_to_adf(text):
    """Convert plain text to Atlassian Document Format."""
    return {
        "type": "doc",
        "version": 1,
        "content": [
            {
                "type": "paragraph",
                "content": [{"type": "text", "text": text}],
            }
        ],
    }


ISSUE_KEY_RE = re.compile(r"^[A-Z][A-Z0-9]+-\d+$")


def validate_issue_key(key):
    """Validate that a string looks like a Jira issue key (e.g. ENG-123)."""
    if not ISSUE_KEY_RE.match(key):
        err(f"'{key}' is not a valid issue key (expected format: PROJ-123).")
        sys.exit(1)


def print_table(headers, rows):
    """Print a formatted ASCII table."""
    widths = [len(h) for h in headers]
    for row in rows:
        for i, cell in enumerate(row):
            widths[i] = max(widths[i], len(str(cell)))

    fmt = "  ".join(f"{{:<{w}}}" for w in widths)
    print(fmt.format(*headers))
    print("  ".join("-" * w for w in widths))
    for row in rows:
        print(fmt.format(*[str(c) for c in row]))


def pick_epic(config):
    """Interactive epic picker. Returns epic key."""
    jql = (
        f"project = {config['project']} AND issuetype = Epic "
        f"AND labels = {config['epic_label']} AND status != Done"
    )

    print(f"\nSearching epics labeled '{config['epic_label']}'...")
    try:
        issues = jql_search(config, jql, ["summary", "status"])
    except JiraError as e:
        err(f"Failed to search epics: {e}")
        sys.exit(1)

    if not issues:
        err(f"No open epics with label '{config['epic_label']}' in {config['project']}.")
        sys.exit(1)

    print()
    for i, issue in enumerate(issues, 1):
        key = issue["key"]
        summary = issue["fields"].get("summary", "")
        status = issue["fields"].get("status", {}).get("name", "")
        print(f"  {i}) {key} — {summary} [{status}]")

    print()
    choice = input(f"Pick an epic (1-{len(issues)}): ").strip()
    try:
        idx = int(choice) - 1
        assert 0 <= idx < len(issues)
    except (ValueError, AssertionError):
        err("Invalid choice.")
        sys.exit(1)

    return issues[idx]["key"]


# ── Templates ───────────────────────────────────────────────

DEFAULT_TEMPLATE = """\
# <enter title here>

## Description


## Acceptance Criteria
- [ ] 

## Story Points


## Assignee
<blank or "me" for yourself, or an email>

## Epic
<KEY or leave blank to pick interactively>
"""


def get_template(issue_type):
    """Return template content for an issue type. Checks ~/.jiramgr/templates/ first."""
    custom = os.path.join(TEMPLATES_DIR, f"{issue_type}.md")
    if os.path.exists(custom):
        with open(custom) as f:
            return f.read()
    return DEFAULT_TEMPLATE


def cmd_install_templates(args):
    """Copy default templates to ~/.jiramgr/templates/ for customization."""
    os.makedirs(TEMPLATES_DIR, exist_ok=True)
    for issue_type in ("story", "task", "spike"):
        path = os.path.join(TEMPLATES_DIR, f"{issue_type}.md")
        with open(path, "w") as f:
            f.write(DEFAULT_TEMPLATE)
        print(f"  {path}")
    print()
    ok(f"Templates installed to {TEMPLATES_DIR}")
    print(f"Edit them to customize defaults for your team.")


def open_editor(content):
    """Open $EDITOR with content, return edited result."""
    editor = os.environ.get("EDITOR", "vim")
    with tempfile.NamedTemporaryFile(suffix=".md", mode="w", delete=False) as tmp:
        tmp.write(content)
        tmp_path = tmp.name
    try:
        subprocess.run([editor, tmp_path], check=True)
        with open(tmp_path) as f:
            return f.read()
    finally:
        os.unlink(tmp_path)


def parse_template(content):
    """Parse a filled-out template into structured fields."""
    result = {
        "summary": None,
        "description_text": "",
        "acceptance_criteria": [],
        "story_points": None,
        "assignee": None,
        "epic": None,
    }

    # Summary: first # heading
    m = re.search(r"^# (.+)$", content, re.MULTILINE)
    if m:
        result["summary"] = m.group(1).strip()

    # Sections: split by ## headings
    parts = re.split(r"^## (.+)$", content, flags=re.MULTILINE)
    # parts[0] = preamble, then alternating heading/body
    for i in range(1, len(parts) - 1, 2):
        heading = parts[i].strip().lower()
        body = parts[i + 1].strip()

        if heading == "description":
            result["description_text"] = body
        elif heading == "acceptance criteria":
            result["acceptance_criteria"] = [
                re.sub(r"^-\s*\[[ x]\]\s*", "", line).strip()
                for line in body.splitlines()
                if line.strip().startswith("- [")
            ]
        elif heading == "story points":
            try:
                result["story_points"] = float(body.strip())
            except ValueError:
                pass
        elif heading == "assignee":
            val = body.strip()
            if val and val.lower() != "me" and not val.startswith("<"):
                result["assignee"] = val
        elif heading == "epic":
            val = body.strip()
            if val and not val.startswith("<"):
                result["epic"] = val

    return result


def markdown_to_adf(description_text, acceptance_criteria):
    """Convert description text + AC list to Atlassian Document Format."""
    content = []

    # Description text -> paragraphs (split on blank lines)
    if description_text:
        for para in re.split(r"\n\s*\n", description_text):
            para = para.strip()
            if para:
                content.append({
                    "type": "paragraph",
                    "content": [{"type": "text", "text": para}],
                })

    # Acceptance criteria -> heading + task list
    if acceptance_criteria:
        content.append({
            "type": "heading",
            "attrs": {"level": 3},
            "content": [{"type": "text", "text": "Acceptance Criteria"}],
        })
        tasks = []
        for item in acceptance_criteria:
            tasks.append({
                "type": "task",
                "attrs": {"state": "TODO"},
                "content": [{"type": "text", "text": item}],
            })
        content.append({"type": "taskList", "content": tasks})

    return {"type": "doc", "version": 1, "content": content}


def resolve_assignee(config, assignee_text):
    """Resolve assignee text to a Jira accountId. Returns None for self."""
    if not assignee_text or assignee_text.lower() == "me":
        # Get current user's accountId
        try:
            result = api(config, "GET", "/rest/api/3/myself")
            return result.get("accountId")
        except JiraError:
            return None
    # Try user search by email/name
    try:
        result = api(config, "GET", f"/rest/api/3/user/search?query={quote(assignee_text)}")
        if result and isinstance(result, list) and result:
            return result[0].get("accountId")
    except JiraError:
        warn(f"Could not find user '{assignee_text}'. No assignee set.")
    return None


# ── Commands ─────────────────────────────────────────────────

def cmd_setup(args):
    """Interactive setup walkthrough."""
    print(f"\n{C.BOLD}jiramgr setup{C.NC}\n")

    # Load existing config so prompts can show current values
    existing = {}
    if os.path.exists(CONFIG_PATH) and not os.path.islink(CONFIG_PATH):
        try:
            with open(CONFIG_PATH) as f:
                existing = json.load(f)
        except (json.JSONDecodeError, OSError):
            pass

    def prompt(label, key, password=False):
        """Prompt for a value. Press Enter to keep current."""
        current = existing.get(key, "")
        hint = f" [{current}]" if current else ""
        if password:
            print(f"\nGet your API token at:")
            print(f"  {C.BOLD}https://id.atlassian.com/manage-profile/security/api-tokens{C.NC}")
            val = getpass.getpass(f"{label}{hint} (hidden): ").strip()
        else:
            val = input(f"{label}{hint}: ").strip()
        return val if val else current

    try:
        # 1. Instance URL
        base_url = prompt("Jira instance URL (https://xxx.atlassian.net)", "base_url")
        if not base_url:
            err("Instance URL is required.")
            sys.exit(1)
        if not base_url.startswith("https://"):
            base_url = "https://" + base_url
        base_url = base_url.rstrip("/")

        # 2. Email
        user = prompt("Your email", "user")
        if not user:
            err("Email is required.")
            sys.exit(1)

        # 3. API token
        api_token = prompt("API token", "api_token", password=True)
        if not api_token:
            err("API token is required.")
            sys.exit(1)

        # Test connection
        config = {"base_url": base_url, "user": user, "api_token": api_token}
        print("\nTesting connection...")
        projects = api(config, "GET", "/rest/api/3/project")
        ok(f"  Connected! Found {len(projects)} projects.")

        if not projects:
            err("No accessible projects found. Check your Jira permissions.")
            sys.exit(1)

        # 4. Project selection
        current_project = existing.get("project", "")
        print("\nAvailable projects:")
        projects.sort(key=lambda p: p.get("key", ""))
        for i, proj in enumerate(projects, 1):
            marker = " (current)" if proj["key"] == current_project else ""
            print(f"  {i}) {proj['key']} — {proj['name']}{marker}")

        print()
        default_idx = next(
            (i for i, p in enumerate(projects, 1) if p["key"] == current_project),
            None,
        )
        prompt_text = f"Select project (1-{len(projects)})"
        if default_idx:
            prompt_text += f" [{default_idx}]"
        choice = input(prompt_text + ": ").strip()
        choice = choice if choice else (str(default_idx) if default_idx else "")
        if not choice:
            err("Project selection is required.")
            sys.exit(1)
        project = projects[int(choice) - 1]["key"]

        # 5. Auto-detect custom field IDs
        print("\nFinding custom field IDs...")
        fields = api(config, "GET", "/rest/api/3/field")
        epic_link_field = None
        sprint_field = None
        story_points_field = None
        for f in fields:
            name = f.get("name", "").lower()
            if name == "epic link":
                epic_link_field = f["id"]
            elif name == "sprint":
                sprint_field = f["id"]
            elif name == "story points":
                story_points_field = f["id"]

        cur_epic = existing.get("epic_link_field", "")
        cur_sprint = existing.get("sprint_field", "")
        cur_sp = existing.get("story_points_field", "")

        if epic_link_field:
            ok(f"  Epic Link: {epic_link_field}")
        else:
            val = input(f"  Epic Link not found. Enter field ID [{cur_epic}]: ").strip()
            epic_link_field = val or cur_epic

        if sprint_field:
            ok(f"  Sprint: {sprint_field}")
        else:
            val = input(f"  Sprint not found. Enter field ID [{cur_sprint}]: ").strip()
            sprint_field = val or cur_sprint

        if story_points_field:
            ok(f"  Story Points: {story_points_field}")
        else:
            val = input(f"  Story Points not found. Enter field ID [{cur_sp}]: ").strip()
            story_points_field = val or cur_sp

        # 6. Epic label
        epic_label = prompt("Epic label (for long-lived epics)", "epic_label")

        # Save
        config.update({
            "project": project,
            "epic_label": epic_label,
            "epic_link_field": epic_link_field,
            "sprint_field": sprint_field,
            "story_points_field": story_points_field,
        })

        save_config(config)
        print()
        ok(f"Config saved to {CONFIG_PATH}")
        print(f"\nTemplates: {TEMPLATES_DIR}")
        print(f"\nYou're ready! Try: {C.BOLD}jiramgr mine{C.NC}")

    except KeyboardInterrupt:
        print("\n\nSetup cancelled.")
        sys.exit(1)
    except JiraError as e:
        err(f"Setup failed: {e}")
        sys.exit(1)
    except (ValueError, IndexError):
        err("Invalid selection.")
        sys.exit(1)


def cmd_create(args):
    """Create a new issue."""
    config = load_config()

    if args.sprint and args.backlog:
        err("Cannot use --sprint and --backlog together.")
        sys.exit(1)

    issue_type = args.type.capitalize()

    # If no summary and no template, prompt for summary inline
    if not args.summary and not args.template:
        args.summary = input(f"{issue_type} summary: ").strip()
        if not args.summary:
            err("Summary is required.")
            sys.exit(1)

    # ── Template mode: open editor, parse result ──
    parsed = None
    if args.template:
        template = get_template(args.type)
        # Pre-fill summary if provided on CLI
        if args.summary:
            template = re.sub(r"^# .+$", f"# {args.summary}", template, count=1, flags=re.MULTILINE)
        print(f"\nOpening {args.type} template in {os.environ.get('EDITOR', 'vim')}...")
        edited = open_editor(template)
        parsed = parse_template(edited)

        if not parsed["summary"] or parsed["summary"].startswith("<"):
            err("Summary is required. Edit the '# ...' line in the template.")
            sys.exit(1)
        if not args.summary:
            args.summary = parsed["summary"]

    # ── Resolve epic ──
    if args.epic:
        epic_key = args.epic
    elif parsed and parsed["epic"]:
        epic_key = parsed["epic"]
    else:
        epic_key = pick_epic(config)
    validate_issue_key(epic_key)

    # ── Resolve sprint ──
    sprint_id = None
    if args.backlog:
        pass
    elif args.sprint:
        try:
            sprint_id = find_active_sprint(config)
        except JiraError:
            sprint_id = None
        if not sprint_id:
            warn("No active sprint found. Going to backlog.")
    else:
        print()
        ans = input("Add to current sprint? [Y/n] ").strip().lower()
        if ans != "n":
            try:
                sprint_id = find_active_sprint(config)
            except JiraError:
                sprint_id = None
            if not sprint_id:
                warn("No active sprint found. Going to backlog.")

    # ── Build fields ──
    fields = {
        "project": {"key": config["project"]},
        "summary": args.summary,
        "issuetype": {"name": issue_type},
        config["epic_link_field"]: epic_key,
    }
    if sprint_id:
        fields[config["sprint_field"]] = sprint_id

    # Template-specific fields
    if parsed:
        # Description (ADF)
        desc_adf = markdown_to_adf(parsed["description_text"], parsed["acceptance_criteria"])
        if desc_adf["content"]:
            fields["description"] = desc_adf

        # Story points
        if parsed["story_points"] and config.get("story_points_field"):
            fields[config["story_points_field"]] = parsed["story_points"]

        # Assignee
        assignee_id = resolve_assignee(config, parsed["assignee"])
        if assignee_id:
            fields["assignee"] = {"accountId": assignee_id}
    else:
        # Quick-create: default assignee to current user
        try:
            myself = api(config, "GET", "/rest/api/3/myself")
            fields["assignee"] = {"accountId": myself.get("accountId")}
        except JiraError:
            pass

    # ── Create ──
    print()
    if sprint_id:
        print(f"Creating {issue_type} → {epic_key} (sprint {sprint_id})...")
    else:
        print(f"Creating {issue_type} → {epic_key} (backlog)...")

    try:
        result = api(config, "POST", "/rest/api/3/issue", {"fields": fields})
        key = result["key"]
        ok(f"{key} — {config['base_url']}/browse/{key}")
    except JiraError as e:
        err(f"Failed to create issue: {e}")
        sys.exit(1)


def cmd_mine(args):
    """List issues assigned to current user."""
    config = load_config()
    project = config["project"]

    if args.backlog:
        jql = (
            f"assignee = currentUser() AND project = {project} "
            f"AND sprint IS EMPTY AND status != Done"
        )
        print("\nYour cards in the backlog:\n")
    else:
        jql = (
            f"assignee = currentUser() AND project = {project} "
            f"AND sprint in openSprints() AND status != Done"
        )
        print("\nYour cards in the active sprint:\n")

    try:
        issues = jql_search(config, jql, ["issuetype", "priority", "status", "summary"])
    except JiraError as e:
        err(f"Failed to search: {e}")
        sys.exit(1)

    if not issues:
        print("  (none)")
        return

    rows = []
    for issue in issues:
        f = issue.get("fields", {})
        rows.append([
            issue["key"],
            f.get("issuetype", {}).get("name", ""),
            (f.get("priority") or {}).get("name", ""),
            f.get("status", {}).get("name", ""),
            f.get("summary", ""),
        ])

    print_table(["Key", "Type", "Priority", "Status", "Summary"], rows)


def cmd_move(args):
    """Transition an issue to a different status."""
    config = load_config()
    issue = args.issue
    validate_issue_key(issue)

    # Fetch available transitions
    try:
        result = api(config, "GET", f"/rest/api/3/issue/{issue}/transitions")
    except JiraError as e:
        err(f"Failed to fetch transitions for {issue}: {e}")
        sys.exit(1)

    transitions = result.get("transitions", [])
    if not transitions:
        err(f"No transitions available for {issue}.")
        sys.exit(1)

    if args.status:
        # Direct: match by name (case-insensitive)
        match = next(
            (t for t in transitions if t["name"].lower() == args.status.lower()),
            None,
        )
        if not match:
            available = ", ".join(t["name"] for t in transitions)
            err(f"'{args.status}' is not a valid transition. Available: {available}")
            sys.exit(1)
        transition_id = match["id"]
        target = match["name"]
    else:
        # Interactive: list transitions, let user pick
        print(f"\nAvailable transitions for {issue}:")
        for i, t in enumerate(transitions, 1):
            print(f"  {i}) {t['name']}")
        print()

        choice = input(f"Pick a transition (1-{len(transitions)}): ").strip()
        try:
            idx = int(choice) - 1
            assert 0 <= idx < len(transitions)
        except (ValueError, AssertionError):
            err("Invalid choice.")
            sys.exit(1)

        transition_id = transitions[idx]["id"]
        target = transitions[idx]["name"]

    # Transition using the integer ID (v3 API requirement)
    try:
        api(config, "POST", f"/rest/api/3/issue/{issue}/transitions",
            {"transition": {"id": int(transition_id)}})
        ok(f"{issue} → {target}")
    except JiraError as e:
        err(f"Failed to transition {issue}: {e}")
        sys.exit(1)


def cmd_comment(args):
    """Add a comment to an issue."""
    config = load_config()
    issue = args.issue
    validate_issue_key(issue)

    text = args.text
    if not text:
        text = input("Comment: ").strip()
    if not text:
        err("Comment text is required.")
        sys.exit(1)

    try:
        api(config, "POST", f"/rest/api/3/issue/{issue}/comment",
            {"body": text_to_adf(text)})
        ok(f"{issue} — comment added")
    except JiraError as e:
        err(f"Failed to add comment: {e}")
        sys.exit(1)


# ── Main ─────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="jiramgr",
        description="Simple Jira card manager",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    # setup
    p = subparsers.add_parser("setup", help="Interactive setup walkthrough")
    p.set_defaults(func=cmd_setup)

    # install-templates
    p = subparsers.add_parser("install-templates", help="Copy default templates to ~/.jiramgr/templates/")
    p.set_defaults(func=cmd_install_templates)

    # create: story | task | spike
    for issue_type in ("story", "task", "spike"):
        p = subparsers.add_parser(issue_type, help=f"Create a {issue_type}")
        p.add_argument("summary", nargs="?", help="Issue summary (prompts if omitted)")
        p.add_argument("-e", "--epic", help="Epic key (skip epic picker)")
        p.add_argument("-t", "--template", action="store_true", help="Open $EDITOR with structured template")
        p.add_argument("--sprint", action="store_true", help="Assign to active sprint")
        p.add_argument("--backlog", action="store_true", help="Keep in backlog")
        p.set_defaults(func=cmd_create, type=issue_type)

    # mine
    p = subparsers.add_parser("mine", help="List your cards")
    p.add_argument("--backlog", action="store_true", help="Show backlog instead of sprint")
    p.set_defaults(func=cmd_mine)

    # move
    p = subparsers.add_parser("move", help="Transition a card")
    p.add_argument("issue", help="Issue key (e.g. ENG-123)")
    p.add_argument("status", nargs="?", help="Target status (skip interactive picker)")
    p.set_defaults(func=cmd_move)

    # comment
    p = subparsers.add_parser("comment", help="Add a comment")
    p.add_argument("issue", help="Issue key")
    p.add_argument("text", nargs="?", help="Comment text (prompts if omitted)")
    p.set_defaults(func=cmd_comment)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
